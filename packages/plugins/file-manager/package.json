{
    "name": "@paperclipai/plugin-file-manager",
    "version": "0.1.0",
    "type": "module",
    "private": true,
    "exports": {
        ".": "./dist/index.js"
    },
    "paperclipPlugin": {
        "manifest": "./dist/manifest.js",
        "worker": "./dist/worker.js",
        "ui": "./dist/ui/"
    },
    "scripts": {
        "build": "tsc && node ./scripts/build-ui.mjs",
        "typecheck": "pnpm --filter @paperclipai/plugin-sdk build && tsc --noEmit"
    },
    "dependencies": {
        "@paperclipai/plugin-sdk": "workspace:*"
    },
    "devDependencies": {
        "@types/node": "^24.6.0",
        "@types/react": "^19.0.8",
        "@types/react-dom": "^19.0.3",
        "esbuild": "^0.27.3",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "typescript": "^5.7.3"
    },
    "peerDependencies": {
        "react": ">=18"
    }
}